# Anna Environment Variables (Example)
# Rename this file to .env and fill in your actual keys

# PRD 4: Notion Integration
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# The ID of the parent page where Anna will create her pages
# (Found in the Notion URL of the page you want to use)
NOTION_PARENT_PAGE_ID=your_parent_page_id_here
